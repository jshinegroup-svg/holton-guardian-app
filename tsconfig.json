{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "app/**",
    "components/**",
    "constants/**",
    "hooks/**",
    "scripts/reset-project.js",
    "expo-env.d.ts",
    "dist/**"
  ]
}
