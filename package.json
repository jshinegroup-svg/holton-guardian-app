{
  "name": "holton-guardian-app",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint App.tsx app.config.js eslint.config.js scripts/**/*.mjs",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "config:public": "npx expo config --type public",
    "export:web": "npx expo export --platform web",
    "build:readiness": "node ./scripts/build-readiness.mjs",
    "assets:audit": "python3 ./scripts/card-asset-tool.py audit",
    "assets:coverage": "python3 ./scripts/card-coverage-audit.py",
    "assets:optimize:cards": "python3 ./scripts/card-asset-tool.py optimize",
    "preflight": "npm run doctor && npm run typecheck && npm run lint",
    "preflight:standalone": "npm run preflight && npm run build:readiness && npm run config:public",
    "preflight:preview-local": "npm run preflight:standalone && npm run export:web",
    "handoff:preview": "node ./scripts/preview-handoff.mjs",
    "handoff:ios": "node ./scripts/ios-build-handoff.mjs",
    "eas:login": "npx expo login",
    "eas:init": "npx eas project:init",
    "build:preview:android": "npx eas build --platform android --profile preview",
    "build:preview:ios:simulator": "npx eas build --platform ios --profile preview-ios-simulator",
    "build:preview:ios:device": "npx eas build --platform ios --profile preview-ios-device",
    "build:testflight:ios": "npx eas build --platform ios --profile testflight",
    "submit:testflight:ios": "npx eas submit --platform ios --profile testflight --latest",
    "build:production:android": "npx eas build --platform android --profile production",
    "build:production:ios": "npx eas build --platform ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
